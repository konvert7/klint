{
  "name": "@konvert7/klint",
  "version": "0.14.0",
  "description": "Architecture-as-Code linter for TypeScript. Enforce layer boundaries, import rules, and singleton patterns in YAML.",
  "type": "module",
  "bin": {
    "klint": "cli.ts"
  },
  "files": [
    "cli.ts",
    "core",
    "rules",
    "plugins",
    "skill",
    "tools",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "architecture",
    "linter",
    "typescript",
    "bun",
    "agent",
    "agentic",
    "arch-as-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konvert7/klint.git"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "test:rust-engine": "bun test tests/rust-engine-cli.test.ts",
    "pack:check": "bun tests/pack-check.ts",
    "native:stage": "bun tests/stage-native-binary.ts",
    "native:smoke": "bun tests/smoke-native-binary.ts",
    "native:release:dry-run": "bun tools/prepare-native-release.ts --version 0.0.0-dry-run",
    "check": "biome check",
    "check-write": "biome check --write",
    "knip": "knip-bun",
    "klint": "bun cli.ts",
    "jscpd": "jscpd --noTips",
    "schema": "bun tools/generate-schema.ts",
    "lint-staged": "lint-staged",
    "prepare": "bun .husky/install.mjs"
  },
  "lint-staged": {
    "*.ts": [
      "bun run check"
    ]
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/bun": "latest",
    "@types/node": "latest",
    "husky": "^9.1.7",
    "jscpd": "4.2.3",
    "knip": "^6.9.0",
    "lint-staged": "^15.5.2",
    "semantic-release": "^25.0.3"
  },
  "directories": {
    "test": "tests"
  },
  "author": "Konvert7",
  "bugs": {
    "url": "https://github.com/konvert7/klint/issues"
  },
  "homepage": "https://github.com/konvert7/klint#readme"
}
