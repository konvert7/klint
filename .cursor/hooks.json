{
  "version": 1,
  "hooks": {
    "stop": [
      { "command": "bun .agents/hooks/check.ts" },
      { "command": "bun .agents/hooks/type-check.ts" },
      { "command": "bun .agents/hooks/rust-format.ts --cursor" },
      { "command": "bun .agents/hooks/rust-check.ts --cursor" },
      { "command": "bun .agents/hooks/rust-clippy.ts --cursor" },
      { "command": "bun .agents/hooks/rust-engine.ts --cursor" },
      { "command": "bun .agents/hooks/pack-check.ts --cursor" },
      { "command": "bun .agents/hooks/knip.ts" },
      { "command": "bun .agents/hooks/jscpd.ts" },
      { "command": "bun .agents/hooks/klint.ts" }
    ]
  }
}
