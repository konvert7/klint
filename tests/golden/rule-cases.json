[
  {
    "name": "no-string-match flags non-global regex and emits fix",
    "config": {
      "include": ["."],
      "rules": {
        "no-string-match": "error"
      }
    },
    "files": {
      "src/subject.ts": "const hit = \"abc\".match(/a/);\n"
    },
    "expected": {
      "violations": [
        {
          "file": "src/subject.ts",
          "line": 1,
          "rule": "no-string-match",
          "message": "Use RegExp.exec() instead of String.match() for non-global regexes — use new RegExp(/a/).exec(\"abc\") instead.",
          "severity": "error",
          "fix": {
            "startLine": 1,
            "endLine": 1,
            "replacement": "const hit = new RegExp(/a/).exec(\"abc\");"
          }
        }
      ],
      "summary": { "errors": 1, "warnings": 0 }
    }
  },
  {
    "name": "no-string-match ignores global regex",
    "config": {
